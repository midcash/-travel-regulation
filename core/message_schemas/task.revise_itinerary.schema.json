{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Revise Itinerary Request",
  "description": "Orchestrator → Planning Agent: 修订行程请求的 payload schema",
  "type": "object",
  "required": ["draft_id", "feedback_items"],
  "properties": {
    "draft_id": {
      "type": "string",
      "description": "待修订的草稿 ID"
    },
    "feedback_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["dimension", "issue", "suggestion"],
        "properties": {
          "dimension": { "type": "string" },
          "issue": { "type": "string" },
          "suggestion": { "type": "string" },
          "priority": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          }
        }
      }
    },
    "revision_version": {
      "type": "integer",
      "minimum": 0,
      "description": "修订版本号，从 0 开始递增"
    },
    "dimensions": {
      "type": "object"
    }
  }
}
