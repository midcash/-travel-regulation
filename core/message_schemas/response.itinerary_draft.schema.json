{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Itinerary Draft Response",
  "description": "Planning Agent → Orchestrator: 行程草稿响应的 payload schema",
  "type": "object",
  "required": ["draft", "metadata"],
  "properties": {
    "draft": {
      "type": "object",
      "description": "行程草稿内容",
      "required": ["draft_id", "destination", "days"],
      "properties": {
        "draft_id": { "type": "string" },
        "destination": { "type": "object" },
        "days": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "object" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "草稿元信息",
      "required": ["created_at", "version"],
      "properties": {
        "created_at": { "type": "string" },
        "version": { "type": "integer" },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
