{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Validation Report Response",
  "description": "Execution Agent → Orchestrator: 可行性验证报告响应的 payload schema",
  "type": "object",
  "required": ["validation_report", "summary"],
  "properties": {
    "validation_report": {
      "type": "object",
      "description": "详细校验报告",
      "required": ["draft_id", "checks"],
      "properties": {
        "draft_id": { "type": "string" },
        "checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "passed"],
            "properties": {
              "name": { "type": "string" },
              "passed": { "type": "boolean" },
              "details": { "type": "string" }
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "description": "校验结果摘要",
      "required": ["overall_pass", "total_checks", "passed_checks"],
      "properties": {
        "overall_pass": { "type": "boolean" },
        "total_checks": { "type": "integer" },
        "passed_checks": { "type": "integer" },
        "blocking_issues": { "type": "integer" },
        "warnings": { "type": "integer" }
      }
    }
  }
}
