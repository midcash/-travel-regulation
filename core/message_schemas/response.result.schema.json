{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Generic Result Response",
  "description": "任意 Specialist → Orchestrator: 通用结果响应的 payload schema",
  "type": "object",
  "required": ["status", "data"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "partial", "failed"],
      "description": "执行状态"
    },
    "data": {
      "type": "object",
      "description": "响应数据主体"
    },
    "message": {
      "type": "string",
      "description": "可选的附加说明"
    }
  }
}
