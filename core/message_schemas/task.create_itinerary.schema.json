{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Create Itinerary Request",
  "description": "Orchestrator → Planning Agent: 创建行程规划请求的 payload schema",
  "type": "object",
  "required": ["destination", "duration_days", "total_budget"],
  "properties": {
    "destination": {
      "type": "object",
      "required": ["city", "country"],
      "properties": {
        "city": { "type": "string" },
        "country": { "type": "string" }
      }
    },
    "duration_days": {
      "type": "integer",
      "minimum": 1,
      "maximum": 30
    },
    "total_budget": {
      "type": "number",
      "minimum": 0
    },
    "currency": {
      "type": "string",
      "default": "CNY"
    },
    "travelers": {
      "type": "object"
    },
    "preferences": {
      "type": "object"
    },
    "dimensions": {
      "type": "object",
      "properties": {
        "completeness": { "type": "number" },
        "feasibility": { "type": "number" },
        "constraint_satisfaction": { "type": "number" },
        "experience_quality": { "type": "number" },
        "information_accuracy": { "type": "number" }
      }
    }
  }
}
