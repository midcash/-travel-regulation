{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Validate Feasibility Request",
  "description": "Orchestrator → Execution Agent: 可行性验证请求的 payload schema",
  "type": "object",
  "required": ["draft"],
  "properties": {
    "draft": {
      "type": "object",
      "description": "待验证的行程草稿"
    },
    "validate_scope": {
      "type": "array",
      "items": { "type": "string" },
      "description": "可选，限定校验范围（如 ['budget', 'geography']）"
    }
  }
}
