# ============================================================
# TravelPlan Orchestrator — 环境变量配置
# ============================================================
# 使用方法:
#   1. 复制本文件为 .env:  cp .env.example .env
#   2. 填入你的 API key
#   3. .env 已在 .gitignore 中，不会被提交
# ============================================================

# === DeepSeek API (LLM — 行程生成核心) ===
# 注册: https://platform.deepseek.com/
# 获取: Dashboard → API Keys → Create Key
# 文档: https://api-docs.deepseek.com/
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
# 模型可选: deepseek-chat (V3), deepseek-reasoner (R1)
DEEPSEEK_MODEL=deepseek-chat

# === 高德地图 API (地理编码 + 路线 + 交通时间) ===
# 注册: https://lbs.amap.com/
# 获取: 控制台 → 应用管理 → 创建应用 → 添加 Key (选择「Web服务」)
# 免费层: 5,000 次/天
# 文档: https://lbs.amap.com/api/webservice/summary/
AMAP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === 途牛 MCP 开放平台 (酒店/机票/门票) ===
# 注册: https://openapi.tuniu.cn/
# 获取: 创建应用 → 获取 API Key
# 协议: JSON-RPC 2.0 over HTTP
# 文档: https://openapi.tuniu.cn/docs
TUNIU_API_KEY=sk-xxxxxxxxxxxxxxxx

# === 超时与重试 (可选，有默认值) ===
# API_TIMEOUT=15
# API_MAX_RETRIES=3
